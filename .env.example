# Скопируйте в `.env` и подставьте значения из Firebase Console.
# Без этого вход в приложение недоступен (страница /login).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
# Web Push (FCM): Firebase Console → Project settings → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=

# ИИ-провайдер: claude | gemini | auto (рекомендуется claude)
VITE_AI_PROVIDER=claude

# Anthropic Claude API — извлечение ППР, чат, HSE
# Ключ: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=
VITE_CLAUDE_MODEL=claude-haiku-4-5-20251001
VITE_CLAUDE_EXTRACTION_MODEL=claude-haiku-4-5-20251001
# Только NEBOSH и разбор PDF ППР (остальное — Haiku):
VITE_CLAUDE_COMPLEX_EXTRACTION_MODEL=claude-sonnet-4-6

# Google Gemini API (запасной провайдер)
# Ключ: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GEMINI_EXTRACTION_MODEL=gemini-2.5-flash-lite

# Устаревший прокси LLM (если Gemini не используется):
# VITE_AI_CHAT_URL=

# Cloud Functions (firebase functions:secrets:set GEMINI_API_KEY):
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# Firestore: при ERR_QUIC_PROTOCOL_ERROR в консоли — long polling (авто по умолчанию).
# Принудительно: VITE_FIRESTORE_FORCE_LONG_POLLING=true
